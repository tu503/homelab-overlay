diff --git a/src/osd/ECCommon.cc b/src/osd/ECCommon.cc
index 66e2b1542df..5c1d1af7be0 100644
--- a/src/osd/ECCommon.cc
+++ b/src/osd/ECCommon.cc
@@ -881,6 +881,9 @@ void ECCommon::RMWPipeline::cache_ready(Op &op) {
       r->map_epoch = get_osdmap_epoch();
       r->min_epoch = get_parent()->get_interval_start_epoch();
       r->trace = trace;
+      if (op.otel_ctx.IsValid()) {
